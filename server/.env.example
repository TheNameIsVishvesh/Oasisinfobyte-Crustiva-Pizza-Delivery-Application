# Server Configuration
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database Configuration
# Replace with your actual MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/Crustiva?retryWrites=true&w=majority

# Authentication Setup
# Generate a secure secret using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_super_secret_key_change_me
JWT_EXPIRES_IN=7d

# Resend Email Integration API Key
# Sign up at https://resend.com to get your API key
RESEND_API_KEY=re_your_api_key_here
EMAIL_FROM=Pizza Delivery App <onboarding@resend.dev>

# Razorpay Payment Gateway (Test Mode Keys)
# Sign up at https://razorpay.com to get your test credentials
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret_key
